# ── Stripe (required for payments) ─────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_SUCCESS_URL=https://your-domain.com/thanks
STRIPE_CANCEL_URL=https://your-domain.com/

# ── Server ─────────────────────────────────────────────────────
PORT=8787
HOST=0.0.0.0
PUBLIC_BASE_URL=https://your-domain.com
ADMIN_TOKEN=change-me-to-random-string

# ── Email delivery (optional — Resend) ─────────────────────────
RESEND_API_KEY=re_...
FROM_EMAIL=orders@yourdomain.com

# ── Orchestrator ───────────────────────────────────────────────
RUN_INTERVAL_MINUTES=360
AUTO_STRIPE_SYNC=true
AUTO_BUILD=true

# ── Money Machine notifications (optional, Tier-2 approvals) ───
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# ── Data root (optional — defaults to D:\wealth-engine-data on Windows) ──
# WEALTH_DATA_ROOT=D:\wealth-engine-data
