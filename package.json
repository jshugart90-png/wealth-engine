{
  "name": "wealth-engine",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Autonomous multi-venture wealth machine — independent of social media",
  "scripts": {
    "start": "node core/server.mjs",
    "run": "node core/orchestrator.mjs",
    "run:daemon": "node core/daemon.mjs",
    "stripe:sync": "node core/stripe-sync.mjs",
    "build": "node core/build-all.mjs",
    "install:task": "powershell -ExecutionPolicy Bypass -File deploy/install-scheduled-task.ps1",
    "health": "node core/health-check.mjs",
    "launch": "node scripts/launch.mjs",
    "webhook": "node scripts/setup-webhook.mjs",
    "daily": "node core/daily-wealth.mjs",
    "agent:next": "node scripts/run-agent-cycle.mjs",
    "agent:step": "node scripts/agent-auto-runner.mjs",
    "agent:chain": "node scripts/run-full-agent-chain.mjs",
    "agent:notify": "node scripts/notify-approval.mjs",
    "daemon:mm": "node scripts/money-machine-daemon.mjs",
    "deploy:render": "node scripts/trigger-render-deploy.mjs",
    "github-pro:cycle": "node scripts/github-pro-cycle.mjs",
    "github-pro:once": "node scripts/github-pro-cycle.mjs --once",
    "mobile:sync": "npm run build && cd mobile && npm install && node sync-www.mjs all",
    "mobile:android": "npm run mobile:sync && cd mobile && npm run android:games",
    "mobile:ios": "npm run mobile:sync && cd mobile && npm run ios:games",
    "mobile:preflight": "node scripts/app-store-preflight.mjs --app games",
    "mobile:itch": "npm run build && node scripts/package-games-itch.mjs",
    "summary:overnight": "node scripts/write-overnight-summary.mjs",
    "summary:status": "node scripts/write-wealth-status.mjs",
    "sprint:overnight": "node scripts/overnight-build-sprint.mjs",
    "production:cycle": "node scripts/production-orchestrator.mjs --once",
    "production:loop": "powershell -ExecutionPolicy Bypass -File deploy/production-orchestrator-loop.ps1",
    "production:report": "node scripts/production-orchestrator.mjs --final-report",
    "install:8am-summary": "powershell -ExecutionPolicy Bypass -File deploy/install-8am-summary-task.ps1",
    "verify:payments": "npm run build && node scripts/verify-payment-links.mjs"
  },
  "engines": { "node": ">=20" },
  "dependencies": {
    "better-sqlite3": "^11.9.1"
  }
}
