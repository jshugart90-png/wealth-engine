# Copy to mobile/.env — never commit secrets

# Remote URL mode (live site in WebView) — default for zero-rebuild updates
CAPACITOR_SERVER_URL=https://wealth-engine-0qlj.onrender.com/games/

# AdMob production IDs (replace test IDs before store release)
ADMOB_APP_ID=ca-app-pub-XXXXXXXXXXXXXXXX~YYYYYYYYYY
ADMOB_BANNER_ID=ca-app-pub-XXXXXXXXXXXXXXXX/ZZZZZZZZZZ
ADMOB_REWARDED_ID=ca-app-pub-XXXXXXXXXXXXXXXX/WWWWWWWWWW

# Apple App Store Connect API (Fastlane)
APP_STORE_CONNECT_API_KEY_ID=
APP_STORE_CONNECT_ISSUER_ID=
APP_STORE_CONNECT_API_KEY_PATH=./AuthKey.p8

# Google Play (Fastlane supply)
GOOGLE_PLAY_SERVICE_ACCOUNT_JSON=./play-service-account.json
GOOGLE_PLAY_PACKAGE_NAME=com.wealthengine.gameshub

# Android signing (production — use Play App Signing in Console)
ANDROID_KEYSTORE_PATH=./release.keystore
ANDROID_KEYSTORE_PASSWORD=
ANDROID_KEY_ALIAS=
ANDROID_KEY_PASSWORD=
