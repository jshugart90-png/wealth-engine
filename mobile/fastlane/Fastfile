# Fastlane lanes — see mobile/fastlane/README.md for TestFlight steps
# Env: copy mobile/fastlane/.env.example → mobile/fastlane/.env (gitignored)

default_platform(:android)

def load_app_store_connect_api_key
  api_key_path = ENV["APP_STORE_CONNECT_API_KEY_PATH"]
  UI.user_error!("Set APP_STORE_CONNECT_API_KEY_PATH in fastlane/.env — see .env.example") if api_key_path.to_s.empty?

  app_store_connect_api_key(
    key_id: ENV.fetch("APP_STORE_CONNECT_API_KEY_ID"),
    issuer_id: ENV.fetch("APP_STORE_CONNECT_ISSUER_ID"),
    key_filepath: api_key_path,
    duration: 1200,
    in_house: false
  )
end

platform :android do
  desc "Upload to Google Play internal testing track"
  lane :beta do
    UI.message("Requires: Google Play Console ($25), service account JSON, signed AAB")
    UI.message("Build AAB locally: cd mobile/games/android && ./gradlew bundleRelease")
    gradle(
      project_dir: "games/android",
      task: "bundle",
      build_type: "Release"
    )
    upload_to_play_store(
      track: "internal",
      aab: "games/android/app/build/outputs/bundle/release/app-release.aab",
      json_key: ENV["GOOGLE_PLAY_SERVICE_ACCOUNT_JSON"],
      package_name: ENV.fetch("GOOGLE_PLAY_PACKAGE_NAME", "com.wealthengine.gameshub")
    )
  end

  desc "Production release to Google Play"
  lane :release do
    beta
    upload_to_play_store(
      track: "production",
      aab: "games/android/app/build/outputs/bundle/release/app-release.aab",
      json_key: ENV["GOOGLE_PLAY_SERVICE_ACCOUNT_JSON"],
      package_name: ENV.fetch("GOOGLE_PLAY_PACKAGE_NAME", "com.wealthengine.gameshub")
    )
  end
end

platform :ios do
  desc "Build archive and upload to TestFlight (macOS + Xcode required)"
  lane :beta do
    UI.message("Apple Developer: account active — no fee step")
    UI.message("Requires: macOS, Xcode, App Store Connect API key in fastlane/.env")
    UI.user_error!("Run on macOS with Xcode — see mobile/APP_STORE_MANUAL_STEPS.md") unless UI.mac?

    api_key = load_app_store_connect_api_key

    build_app(
      workspace: "games/ios/App/App.xcworkspace",
      scheme: "App",
      export_method: "app-store",
      clean: true
    )

    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true,
      distribute_external: false
    )

    UI.success("Uploaded to TestFlight — check App Store Connect → TestFlight tab")
  end

  desc "TestFlight upload + App Store metadata (does not auto-submit for review)"
  lane :release do
    beta
    upload_to_app_store(
      api_key: load_app_store_connect_api_key,
      submit_for_review: false,
      automatic_release: false
    )
  end
end
