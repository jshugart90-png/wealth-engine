# Copy to mobile/fastlane/.env — NEVER commit real values or .p8 files
#
# Used by: bundle exec fastlane ios beta
# Full steps: mobile/fastlane/README.md and mobile/APP_STORE_MANUAL_STEPS.md § Apple

# App Store Connect → Users and Access → Integrations → App Store Connect API
APP_STORE_CONNECT_API_KEY_ID=
APP_STORE_CONNECT_ISSUER_ID=
# Absolute path to downloaded AuthKey_XXXXXX.p8 (outside repo recommended)
APP_STORE_CONNECT_API_KEY_PATH=

# Optional — Fastlane Appfile can use these instead of hardcoding
FASTLANE_APPLE_ID=
FASTLANE_TEAM_ID=

# Android (Play Console service account — separate from iOS)
GOOGLE_PLAY_SERVICE_ACCOUNT_JSON=../play-service-account.json
GOOGLE_PLAY_PACKAGE_NAME=com.wealthengine.gameshub
